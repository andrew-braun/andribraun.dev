{
	"name": "andribraun.dev",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint . && stylelint \"src/**/*.{css,scss,svelte}\"",
		"lint:css": "stylelint \"src/**/*.{css,scss,svelte}\"",
		"format": "prettier --write .",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.svelte": [
			"eslint --fix",
			"stylelint --fix",
			"prettier --write"
		],
		"*.{css,scss}": [
			"stylelint --fix",
			"prettier --write"
		],
		"*.{json,md}": [
			"prettier --write"
		]
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@iconify/json": "^2.2.459",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/eslint": "^9.6.1",
		"eslint": "^9.39.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"postcss-html": "^1.8.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"sass": "^1.99.0",
		"stylelint": "^17.6.0",
		"stylelint-config-recess-order": "^7.7.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"svelte-preprocess": "^6.0.3",
		"tslib": "^2.8.1",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.0.3"
	},
	"type": "module",
	"dependencies": {
		"@payloadcms/sdk": "^3.81.0",
		"bits-ui": "^2.17.2",
		"isomorphic-dompurify": "^3.7.1",
		"marked": "^17.0.6",
		"typewriter-effect": "^2.22.0"
	}
}
